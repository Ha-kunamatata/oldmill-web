---
// 클라이언트 사이드 옵저버. 한 번만 로드되면 페이지 전체에서 작동.
---

<script>
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('is-visible');
				observer.unobserve(entry.target);
			}
		});
	}, {
		threshold: 0.12,
		rootMargin: '0px 0px -50px 0px'
	});

	const targets = document.querySelectorAll('.reveal, .reveal-stagger');
	targets.forEach(el => observer.observe(el));

	// Astro의 페이지 전환 시에도 재실행 (View Transitions 사용 시)
	document.addEventListener('astro:page-load', () => {
		const newTargets = document.querySelectorAll('.reveal:not(.is-visible), .reveal-stagger:not(.is-visible)');
		newTargets.forEach(el => observer.observe(el));
	});
</script>