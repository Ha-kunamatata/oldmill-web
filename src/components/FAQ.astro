---
interface Item {
	q: string;
	a: string;
}

interface Props {
	items: Item[];
	title?: string;
	eyebrow?: string;
}

const { items, title = '자주 묻는 질문', eyebrow = 'FAQ' } = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-20 md:py-24 reveal">
	<div class="text-center mb-12 md:mb-16">
		<p class="text-eyebrow mb-4">{eyebrow}</p>
		<h2 class="text-headline">{title}</h2>
	</div>
	<div class="space-y-3">
		{items.map((item, i) => (
			<details class="faq-item group border border-border-warm rounded-xl overflow-hidden bg-bg/50 hover:bg-bg transition-colors">
				<summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
					<div class="flex items-start gap-4">
						<span class="font-serif text-accent text-lg shrink-0">Q.</span>
						<span class="font-medium text-base md:text-lg">{item.q}</span>
					</div>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 mt-1 transition-transform duration-300 group-open:rotate-45">
						<line x1="12" y1="5" x2="12" y2="19" />
						<line x1="5" y1="12" x2="19" y2="12" />
					</svg>
				</summary>
				<div class="px-6 pb-6 pl-16 -mt-1">
					<p class="text-muted leading-relaxed whitespace-pre-line">{item.a}</p>
				</div>
			</details>
		))}
	</div>
</section>

<style>
	details summary::-webkit-details-marker { display: none; }
	details[open] { border-color: var(--color-accent); }
</style>