---
interface Props {
	quote: string;
	author: string;
	context?: string;
}

const { quote, author, context } = Astro.props;
---

<blockquote class="card-bordered p-8 md:p-10 relative">
	<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-accent/20 mb-4">
		<path d="M9.583 17.321C8.553 16.227 8 15 8 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C18.553 16.227 18 15 18 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
	</svg>
	<p class="text-base md:text-lg leading-relaxed mb-6 text-ink">
		{quote}
	</p>
	<footer class="border-t border-border-warm pt-4 flex items-baseline gap-3">
		<cite class="not-italic font-medium">{author}</cite>
		{context && <span class="text-sm text-muted">— {context}</span>}
	</footer>
</blockquote>