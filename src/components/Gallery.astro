---
interface Image {
	src: string;
	alt: string;
	caption?: string;
}

interface Props {
	images: Image[];
	columns?: 2 | 3 | 4;
}

const { images, columns = 3 } = Astro.props;

const colClass = {
	2: 'md:grid-cols-2',
	3: 'md:grid-cols-3',
	4: 'md:grid-cols-4',
}[columns];
---

<div class={`grid grid-cols-2 ${colClass} gap-3 md:gap-4 reveal-stagger`}>
	{images.map(img => (
		<figure class="aspect-square bg-border-warm rounded-lg overflow-hidden relative group">
			<img 
				src={img.src} 
				alt={img.alt}
				loading="lazy"
				class="img-fade w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
				onload="this.classList.add('is-loaded')"
			/>
		</figure>
	))}
</div>