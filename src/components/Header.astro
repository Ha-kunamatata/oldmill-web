---
const navItems = [
	{ label: '소개', href: '/about' },
	{ label: '공간', href: '/space' },
	{
		label: '돌잔치 / 칠·팔순',
		groupHref: '/events/family',
		children: [
			{ label: '돌잔치', href: '/events/doljanchi', desc: '아이의 첫 생일' },
			{ label: '칠·팔순', href: '/events/hwangab', desc: '어르신의 큰 날' },
		],
	},
	{ label: '스몰웨딩', href: '/events/wedding' },
	{ label: '세미나', href: '/events/seminar' },
	{
		label: '피자체험 / 졸업식',
		groupHref: '/events/kids',
		children: [
			{ label: '피자체험', href: '/events/pizza-class', desc: '아이들의 화덕 피자' },
			{ label: '졸업식', href: '/events/graduation', desc: '단체 졸업 행사' },
		],
	},
	{ label: '문의', href: '/contact' },
];
---

<header id="site-header" class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-transparent transition-all duration-300">
	<div id="header-inner" class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between transition-all duration-300">
		<a href="/" class="flex items-center gap-2 group shrink-0">
			<img 
				src="/images/logo.svg" 
				alt="The Old Mill" 
				class="h-8 md:h-10 w-auto transition-transform duration-300 group-hover:scale-105"
			/>
			<span class="font-serif text-xl md:text-2xl font-semibold tracking-wide">THE OLD MILL</span>
		</a>
		
		<!-- PC 메뉴 -->
		<nav class="hidden lg:flex items-center gap-1">
			{navItems.map(item => (
				item.children ? (
					<div class="dropdown-wrap">
						<a 
							href={item.groupHref}
							class="dropdown-trigger px-3 py-2 text-sm text-muted hover:text-ink transition-colors flex items-center gap-1"
						>
							{item.label}
							<svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="dropdown-chevron transition-transform">
								<path d="M3 4.5L6 7.5L9 4.5" />
							</svg>
						</a>
						<div class="dropdown-panel">
							<div class="bg-bg border border-border-warm rounded-xl shadow-lg p-2 min-w-[220px]">
								{item.children.map(child => (
									<a 
										href={child.href}
										class="block px-4 py-3 rounded-lg hover:bg-bg-soft transition-colors group/item"
									>
										<div class="font-medium text-sm group-hover/item:text-accent transition-colors">{child.label}</div>
										<div class="text-xs text-muted mt-0.5">{child.desc}</div>
									</a>
								))}
							</div>
						</div>
					</div>
				) : (
					<a 
						href={item.href} 
						class="px-3 py-2 text-sm text-muted hover:text-ink transition-colors"
					>
						{item.label}
					</a>
				)
			))}
		</nav>

		<a 
			href="/contact" 
			class="hidden lg:inline-block bg-cta text-white px-5 py-2 rounded-full text-sm hover:bg-accent transition-colors shrink-0 ml-4"
		>
			예약 문의
		</a>

		<button 
			id="mobile-menu-toggle"
			class="lg:hidden p-2"
			aria-label="메뉴 열기"
			aria-expanded="false"
		>
			<svg id="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<line x1="3" y1="6" x2="21" y2="6" />
				<line x1="3" y1="12" x2="21" y2="12" />
				<line x1="3" y1="18" x2="21" y2="18" />
			</svg>
			<svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
				<line x1="18" y1="6" x2="6" y2="18" />
				<line x1="6" y1="6" x2="18" y2="18" />
			</svg>
		</button>
	</div>

	<!-- 모바일 메뉴 -->
	<nav 
		id="mobile-menu"
		class="lg:hidden hidden border-t border-border-warm bg-bg max-h-[calc(100vh-80px)] overflow-y-auto"
	>
		<div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
			{navItems.map(item => (
				<a 
					href={item.children ? item.groupHref : item.href} 
					class="py-3 text-base text-ink hover:text-accent transition-colors border-b border-border-warm last:border-b-0 flex items-center justify-between"
				>
					<span>{item.label}</span>
					{item.children && (
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<polyline points="9 18 15 12 9 6" />
						</svg>
					)}
				</a>
			))}
			<a 
				href="/contact" 
				class="mt-4 bg-cta text-white px-5 py-3 rounded-full text-sm text-center hover:bg-accent transition-colors"
			>
				예약 문의
			</a>
		</div>
	</nav>
</header>

<style>
	/* 드롭다운 — Tailwind 그룹 의존 없이 순수 CSS로 처리 */
	.dropdown-wrap {
		position: relative;
	}

	.dropdown-panel {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(-4px);
		padding-top: 8px;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
		z-index: 100;
	}

	.dropdown-wrap:hover .dropdown-panel,
	.dropdown-wrap:focus-within .dropdown-panel {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateX(-50%) translateY(0);
	}

	.dropdown-wrap:hover .dropdown-chevron,
	.dropdown-wrap:focus-within .dropdown-chevron {
		transform: rotate(180deg);
	}
</style>

<script>
	const toggle = document.getElementById('mobile-menu-toggle');
	const menu = document.getElementById('mobile-menu');
	const iconMenu = document.getElementById('icon-menu');
	const iconClose = document.getElementById('icon-close');

	toggle?.addEventListener('click', () => {
		const isOpen = !menu?.classList.contains('hidden');
		menu?.classList.toggle('hidden');
		iconMenu?.classList.toggle('hidden');
		iconClose?.classList.toggle('hidden');
		toggle.setAttribute('aria-expanded', String(!isOpen));
	});

	const header = document.getElementById('site-header');
	const inner = document.getElementById('header-inner');

	const handleScroll = () => {
		const scrollY = window.scrollY;
		if (scrollY > 20) {
			header?.classList.add('header-scrolled');
			inner?.classList.add('header-inner-scrolled');
		} else {
			header?.classList.remove('header-scrolled');
			inner?.classList.remove('header-inner-scrolled');
		}
	};

	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();
</script>