---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';

const floors = [
	{
		floor: '1F',
		eyebrow: 'EVENT HALL',
		title: '돌잔치 · 피자체험 · 스몰웨딩 홀',
		description: '아이의 첫 생일과 작은 결혼식, 그리고 어린이 피자체험까지 진행되는 메인 이벤트 홀입니다.',
		href: '/space/1f-hall',
	},
	{
		floor: '2F',
		eyebrow: 'MAIN DINING',
		title: '일반 식사 (16 테이블)',
		description: '진입층(GR층)에 위치한 메인 다이닝. 16개 테이블 규모로 가족 모임과 일상 식사에 적합합니다.',
		href: '/space/2f-dining',
	},
	{
		floor: '3F',
		eyebrow: 'PRIVATE ROOMS',
		title: '스몰웨딩 A · B룸',
		description: 'A룸과 B룸으로 분리된 프라이빗 공간. 가까운 사람들과의 따뜻한 결혼식을 위한 공간입니다.',
		href: '/space/3f-rooms',
	},
];
---

<BaseLayout title="공간 안내 · THE OLD MILL">
	<PageHero
		eyebrow="OUR SPACE"
		title="3개 층, 3가지 시간"
		subtitle="용도에 맞게 설계된 단독 건물. 각 층마다 다른 분위기와 목적을 가진 공간을 만나보세요."
	/>

	<section class="max-w-5xl mx-auto px-6 pb-20 space-y-6 reveal-stagger">
		{floors.map(f => (
			<a href={f.href} class="card-bordered p-8 md:p-12 block group">
				<div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10">
					<div class="md:w-32 shrink-0">
						<p class="text-eyebrow text-xs mb-2">{f.eyebrow}</p>
						<div class="font-serif text-6xl md:text-7xl text-accent group-hover:translate-x-1 transition-transform duration-500">
							{f.floor}
						</div>
					</div>
					<div class="flex-1">
						<h3 class="font-serif text-2xl md:text-3xl mb-3 group-hover:text-accent transition-colors">
							{f.title}
						</h3>
						<p class="text-muted leading-relaxed">{f.description}</p>
					</div>
					<div class="text-accent text-2xl md:text-3xl group-hover:translate-x-2 transition-transform duration-500">→</div>
				</div>
			</a>
		))}
	</section>

	<CTASection 
		title="공간 견학 가능합니다"
		description="실제 공간을 직접 보시고 행사를 결정하실 수 있도록, 사전 예약 후 견학을 도와드립니다."
		buttonLabel="견학 문의"
	/>
</BaseLayout>