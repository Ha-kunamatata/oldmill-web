---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import Gallery from '../../components/Gallery.astro';
import CTASection from '../../components/CTASection.astro';

const galleryImages = [
	{ src: '/images/space/1f-hall-01.jpg', alt: '1층 홀 전경' },
	{ src: '/images/space/1f-hall-02.jpg', alt: '돌잔치 세팅' },
	{ src: '/images/space/1f-hall-03.jpg', alt: '피자체험 진행' },
	{ src: '/images/space/1f-hall-04.jpg', alt: '스몰웨딩 데코' },
	{ src: '/images/space/1f-hall-05.jpg', alt: '입구' },
	{ src: '/images/space/1f-hall-06.jpg', alt: '음식 상차림' },
];

const events = [
	'돌잔치 · 백일잔치 등 가족 행사',
	'어린이 피자체험 (단체 / 생일파티)',
	'스몰웨딩 (소규모 결혼식)',
];
---

<BaseLayout title="1층 홀 · THE OLD MILL">
	<PageHero
		eyebrow="1ST FLOOR"
		title="이벤트를 위한 공간"
		subtitle="돌잔치, 어린이 피자체험, 스몰웨딩이 진행되는 메인 홀입니다."
	/>

	<section class="max-w-5xl mx-auto px-6 pb-12 reveal">
		<Gallery images={galleryImages} columns={3} />
	</section>

	<Section eyebrow="EVENTS" title="이런 행사를 진행합니다">
		<ul class="space-y-4">
			{events.map(e => (
				<li class="flex gap-4 items-start text-lg">
					<span class="text-accent text-2xl leading-none">·</span>
					<span>{e}</span>
				</li>
			))}
		</ul>
	</Section>

	<Section eyebrow="INFO" title="공간 정보">
		<div class="grid md:grid-cols-2 gap-4">
			<div class="card-bordered p-6">
				<div class="text-sm text-muted mb-2">수용 인원</div>
				<div class="font-medium text-xl">최대 ○○명 (행사별 상이)</div>
			</div>
			<div class="card-bordered p-6">
				<div class="text-sm text-muted mb-2">위치</div>
				<div class="font-medium text-xl">건물 1층 (전용 공간)</div>
			</div>
		</div>
		<p class="text-muted text-sm mt-6">
			※ 정확한 수용 인원과 진행 가능 행사는 문의 시 안내드립니다.
		</p>
	</Section>

	<CTASection 
		title="행사 상담을 받아보세요"
		description="예상 인원, 날짜, 행사 종류를 알려주시면 패키지를 안내해드립니다."
		buttonLabel="문의하기"
	/>
</BaseLayout>