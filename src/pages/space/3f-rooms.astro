---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout title="3층 A·B룸 · THE OLD MILL">
	<PageHero
		eyebrow="3RD FLOOR"
		title="프라이빗한<br/>약속의 시간"
		subtitle="A룸과 B룸으로 분리된 3층 공간에서, 가까운 사람들과 함께하는 따뜻한 결혼식을 진행합니다."
	/>

	<Section eyebrow="ROOMS" title="A룸 / B룸">
		<div class="grid md:grid-cols-2 gap-6 reveal-stagger">
			<div class="card-bordered p-8 md:p-10">
				<div class="font-serif text-6xl text-accent mb-4">A</div>
				<h3 class="font-serif text-2xl mb-3">A룸</h3>
				<p class="text-muted leading-relaxed">
					상세 설명을 여기에 추가하세요. 수용 인원, 분위기, 추천 행사 유형 등.
				</p>
			</div>
			<div class="card-bordered p-8 md:p-10">
				<div class="font-serif text-6xl text-accent mb-4">B</div>
				<h3 class="font-serif text-2xl mb-3">B룸</h3>
				<p class="text-muted leading-relaxed">
					상세 설명을 여기에 추가하세요.
				</p>
			</div>
		</div>
	</Section>

	<CTASection 
		title="스몰웨딩 상담"
		description="가까운 분들과의 작은 결혼식, 어울리는 룸을 안내해드립니다."
		buttonLabel="상담 문의"
	/>
</BaseLayout>