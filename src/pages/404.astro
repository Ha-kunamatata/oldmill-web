---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없음 · THE OLD MILL">
	<section class="max-w-2xl mx-auto px-6 py-32 text-center">
		<p class="font-serif text-accent text-lg mb-4">404</p>
		<h1 class="font-serif text-4xl md:text-5xl mb-6">
			길을 잃으셨나요?
		</h1>
		<p class="text-muted text-lg mb-10">
			찾으시던 페이지가 없거나 이동되었습니다.
		</p>
		<a href="/" class="inline-block bg-cta text-white px-8 py-3 rounded-full hover:bg-accent transition-colors">
			처음으로 돌아가기
		</a>
	</section>
</BaseLayout>