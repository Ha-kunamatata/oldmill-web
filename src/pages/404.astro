---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없음 · THE OLD MILL">
	<section class="max-w-2xl mx-auto px-6 py-32 md:py-48 text-center reveal">
		<p class="text-eyebrow mb-6">404</p>
		<h1 class="text-display mb-8">
			길을 잃으셨나요?
		</h1>
		<p class="prose-body mb-12">
			찾으시던 페이지가 없거나 이동되었습니다.
		</p>
		<div class="flex flex-col sm:flex-row gap-3 justify-center">
			<a href="/" class="btn btn-cta"><span>처음으로 돌아가기</span></a>
			<a href="/contact" class="btn btn-outline"><span>문의하기</span></a>
		</div>
	</section>
</BaseLayout>