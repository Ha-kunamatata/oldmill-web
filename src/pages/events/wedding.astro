---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';
import FAQ from '../../components/FAQ.astro';
import InfoCard from '../../components/InfoCard.astro';
import SmartImage from '../../components/SmartImage.astro';

const venues = [
	{
		floor: '1F',
		title: '1층 메인 홀',
		capacity: '50~80명',
		mood: '넓고 개방적인 분위기',
		desc: '하객이 많은 결혼식에 적합한 메인 홀. 데코의 자유도가 높고, 식사·예식·환담이 한 공간에서 자연스럽게 이어집니다.',
	},
	{
		floor: '3F',
		title: '3층 A · B룸',
		capacity: '20~40명',
		mood: '프라이빗하고 따뜻한 분위기',
		desc: '진짜 가까운 사람들만 모시는 작은 결혼식. 룸 단위로 운영되어 외부와 완전히 분리된 시간을 보낼 수 있습니다.',
	},
];

const includes = [
	{ icon: '◆', title: '홀 또는 룸 단독 사용', desc: '예식 시간 동안 외부 손님 없이 진행' },
	{ icon: '◆', title: '기본 웨딩 데코', desc: '아치, 버진로드, 테이블 세팅' },
	{ icon: '◆', title: '코스 식사', desc: '하객 인원에 맞춘 코스 메뉴' },
	{ icon: '◆', title: '음료 / 케이크', desc: '웰컴드링크부터 케이크 컷팅까지' },
	{ icon: '◆', title: '진행 보조', desc: '간단한 식순 안내 및 진행' },
	{ icon: '◆', title: '주차 / 안내', desc: '하객 주차 및 동선 안내' },
];

const flow = [
	{ step: '01', title: '상담 신청', desc: '예상 인원, 희망 날짜, 원하시는 분위기를 알려주세요.' },
	{ step: '02', title: '현장 방문', desc: '두 공간(1F/3F)을 직접 보시고 어울리는 곳을 정합니다.' },
	{ step: '03', title: '계약 및 준비', desc: '식순, 메뉴, 데코를 확정하고 D-Day까지 조율합니다.' },
	{ step: '04', title: '예식 당일', desc: '두 분과 가까운 사람들을 위한 따뜻한 시간이 됩니다.' },
];

const faqs = [
	{
		q: '하객은 몇 명까지 가능한가요?',
		a: '1층 메인 홀은 약 50~80명, 3층 A·B룸은 20~40명 규모에 적합합니다. 정확한 수용 인원은 상담 시 안내드립니다.',
	},
	{
		q: '예식만 진행할 수도 있나요? 식사 없이?',
		a: '기본적으로 예식 + 식사 패키지로 운영됩니다. 식사 없는 진행은 별도 협의가 필요합니다.',
	},
	{
		q: '주례 / 사회는 직접 섭외해야 하나요?',
		a: '주례·사회는 보통 가족이나 지인이 맡으시는 경우가 많지만, 외부 진행자 섭외가 필요하시면 안내해 드릴 수 있습니다.',
	},
	{
		q: '웨딩 촬영은 어떻게 하나요?',
		a: '저희가 직접 촬영을 진행하지는 않지만, 협력하는 작가님을 소개해 드릴 수 있습니다. 직접 섭외도 환영합니다.',
	},
	{
		q: '드레스 / 헤어메이크업은요?',
		a: '드레스·HMU는 신부님이 직접 준비하시면 됩니다. 필요하시면 인근 업체를 안내해 드립니다.',
	},
	{
		q: '예약은 얼마나 미리 해야 하나요?',
		a: '주말 결혼식은 보통 3~6개월 전에 예약이 차는 편입니다. 평일은 좀 더 여유 있습니다.',
	},
];
---

<BaseLayout title="스몰웨딩 · THE OLD MILL" description="아산 스몰웨딩, 1층 홀과 3층 A·B룸에서 진행하는 따뜻한 결혼식">
	<PageHero
		eyebrow="SMALL WEDDING · 스몰웨딩"
		title="가까운 사람들과<br/>따뜻하게"
		subtitle="대형 예식장이 아닌, 진짜 의미 있는 사람들만의 시간. 두 분만의 결혼식을 만들어 드립니다."
	/>

	<section class="w-full mb-24 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<SmartImage 
				src="/images/events/wedding-hero.jpg"
				alt="스몰웨딩 진행 모습"
				aspectRatio="21/9"
				rounded="2xl"
				label="스몰웨딩 진행 모습"
			/>
		</div>
	</section>

	<Section eyebrow="VENUE" title="두 가지 공간 중<br/>선택하실 수 있습니다">
		<div class="grid md:grid-cols-2 gap-6 md:gap-8 reveal-stagger">
			{venues.map(v => (
				<div class="card-bordered p-8 md:p-10">
					<div class="font-serif text-6xl text-accent mb-6 leading-none">{v.floor}</div>
					<h3 class="font-serif text-2xl mb-4">{v.title}</h3>
					<div class="space-y-3 mb-6">
						<div class="flex gap-3">
							<span class="text-xs text-muted uppercase tracking-wider w-20 shrink-0">수용</span>
							<span class="text-sm">{v.capacity}</span>
						</div>
						<div class="flex gap-3">
							<span class="text-xs text-muted uppercase tracking-wider w-20 shrink-0">분위기</span>
							<span class="text-sm">{v.mood}</span>
						</div>
					</div>
					<p class="text-muted leading-relaxed text-sm">{v.desc}</p>
				</div>
			))}
		</div>
	</Section>

	<section class="bg-bg-soft py-20 md:py-24 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-eyebrow mb-4">GALLERY</p>
				<h2 class="text-headline">진행된 스몰웨딩</h2>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 reveal-stagger">
				{[1,2,3,4,5,6].map(i => (
					<SmartImage 
						src={`/images/events/wedding-${String(i).padStart(2,'0')}.jpg`}
						alt={`웨딩 사진 ${i}`}
						aspectRatio="1/1"
						rounded="lg"
						label={`웨딩 ${i}`}
						hover
					/>
				))}
			</div>
		</div>
	</section>

	<Section eyebrow="PACKAGE" title="패키지 포함 사항">
		<div class="grid md:grid-cols-2 gap-4 md:gap-6 reveal-stagger">
			{includes.map(item => (
				<div class="card-bordered p-6 flex gap-5 items-start">
					<div class="font-serif text-2xl text-accent shrink-0 leading-none mt-1">{item.icon}</div>
					<div>
						<div class="font-medium text-lg mb-1">{item.title}</div>
						<p class="text-muted text-sm leading-relaxed">{item.desc}</p>
					</div>
				</div>
			))}
		</div>
		<p class="text-muted text-sm mt-10 pt-6 border-t border-border-warm">
			※ 패키지 구성과 가격은 인원·날짜·옵션에 따라 조정됩니다.
		</p>
	</Section>

	<section class="bg-bg-soft py-24 md:py-32 reveal">
		<div class="max-w-4xl mx-auto px-6">
			<div class="text-center mb-16">
				<p class="text-eyebrow mb-4">PROCESS</p>
				<h2 class="text-headline">진행 흐름</h2>
			</div>
			<ol class="space-y-12 reveal-stagger">
				{flow.map(f => (
					<li class="grid md:grid-cols-[6rem_1fr] gap-6 md:gap-10 items-start">
						<div class="font-serif text-4xl md:text-5xl text-accent leading-none">{f.step}</div>
						<div class="md:pt-1">
							<div class="font-medium text-xl mb-3">{f.title}</div>
							<p class="text-muted leading-relaxed">{f.desc}</p>
						</div>
					</li>
				))}
			</ol>
		</div>
	</section>

	<Section eyebrow="AT A GLANCE" title="한눈에 보기">
		<div class="grid md:grid-cols-3 gap-6 reveal-stagger">
			<InfoCard label="권장 인원" value="20명 — 80명" hint="공간 선택에 따라" />
			<InfoCard label="소요 시간" value="약 2~3시간" hint="식사 포함" />
			<InfoCard label="예약 시점" value="3~6개월 전" hint="주말 일정은 더 일찍" />
		</div>
	</Section>

	<FAQ items={faqs} />

	<CTASection 
		title="두 분만의 결혼식을<br/>상상해 보세요"
		description="예상 인원, 희망 날짜를 알려주시면 가능한 공간과 패키지를 안내드립니다."
		buttonLabel="스몰웨딩 상담"
		phone="041-546-1080"
	/>
</BaseLayout>