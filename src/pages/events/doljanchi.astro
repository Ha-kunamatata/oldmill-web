---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
---

<BaseLayout title="돌잔치 · THE OLD MILL" description="아산 돌잔치, 올드밀 1층 전용 홀에서">
	<PageHero
		eyebrow="DOLJANCHI"
		title="아이의 첫 생일,<br/>가족의 잊지 못할 하루"
		subtitle="1층 전용 홀에서 진행되는 프리미엄 돌잔치. 가족만의 시간이 되도록 세심하게 준비합니다."
	/>

	<Section title="패키지에 포함되는 것">
		<div class="grid md:grid-cols-2 gap-4">
			{[
				'1층 전용 홀 사용',
				'기본 데코레이션 (테이블/배경)',
				'코스 메뉴 (인원수 기준)',
				'음료 / 디저트 세팅',
				'사회 진행 (선택)',
				'주차 안내',
			].map(item => (
				<div class="flex gap-3 items-start">
					<span class="text-accent text-xl mt-0.5">✓</span>
					<span class="text-lg">{item}</span>
				</div>
			))}
		</div>
		<p class="text-muted text-sm mt-8">
			※ 패키지 구성은 인원·예산에 따라 조정 가능합니다. 자세한 내용은 상담 시 안내드립니다.
		</p>
	</Section>

	<Section title="진행 흐름">
		<ol class="space-y-6">
			<li class="flex gap-4">
				<div class="font-serif text-2xl text-accent w-8 shrink-0">1</div>
				<div>
					<div class="font-semibold text-lg mb-1">예약 문의</div>
					<p class="text-muted">희망 날짜, 예상 인원을 알려주세요.</p>
				</div>
			</li>
			<li class="flex gap-4">
				<div class="font-serif text-2xl text-accent w-8 shrink-0">2</div>
				<div>
					<div class="font-semibold text-lg mb-1">현장 답사 및 상담</div>
					<p class="text-muted">공간을 직접 보시고 패키지를 결정합니다.</p>
				</div>
			</li>
			<li class="flex gap-4">
				<div class="font-serif text-2xl text-accent w-8 shrink-0">3</div>
				<div>
					<div class="font-semibold text-lg mb-1">계약 및 진행 준비</div>
					<p class="text-muted">메뉴, 데코, 진행 순서를 확정합니다.</p>
				</div>
			</li>
			<li class="flex gap-4">
				<div class="font-serif text-2xl text-accent w-8 shrink-0">4</div>
				<div>
					<div class="font-semibold text-lg mb-1">행사 당일</div>
					<p class="text-muted">가족과 함께하는 특별한 하루.</p>
				</div>
			</li>
		</ol>
	</Section>

	<section class="bg-cta text-white">
		<div class="max-w-4xl mx-auto px-6 py-16 text-center">
			<h2 class="font-serif text-3xl mb-6">먼저 일정부터 확인해 보세요</h2>
			<a href="/contact" class="inline-block bg-white text-cta px-8 py-3 rounded-full hover:bg-bg transition-colors">
				돌잔치 문의하기
			</a>
		</div>
	</section>
</BaseLayout>