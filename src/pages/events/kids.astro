---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import SmartImage from '../../components/SmartImage.astro';

const events = [
	{
		title: '피자체험',
		eyebrow: 'PIZZA CLASS',
		description: '아이들이 직접 만드는 화덕 피자. 단체 예약 및 생일파티 가능.',
		href: '/events/pizza-class',
		image: '/images/events/pizza-cover.jpg',
	},
	{
		title: '졸업식',
		eyebrow: 'GRADUATION',
		description: '어린이집·유치원·학원의 단체 졸업식. 아이들의 마지막을 특별하게.',
		href: '/events/graduation',
		image: '/images/events/graduation-cover.jpg',
	},
];
---

<BaseLayout title="아이들을 위한 시간 · THE OLD MILL" description="피자체험과 졸업식, 아이들의 특별한 시간">
	<PageHero
		eyebrow="FOR KIDS"
		title="아이들을 위한<br/>특별한 시간"
		subtitle="직접 만드는 화덕 피자 체험부터 단체 졸업식까지. 아이들이 즐겁게 머무는 공간입니다."
	/>

	<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
		<div class="grid md:grid-cols-2 gap-6 md:gap-8 reveal-stagger">
			{events.map(e => (
				<a href={e.href} class="group card-hover block">
					<div class="mb-5">
						<SmartImage 
							src={e.image}
							alt={e.title}
							aspectRatio="4/5"
							rounded="xl"
							label={e.title}
							hover
						/>
					</div>
					<p class="text-eyebrow mb-2 text-xs">{e.eyebrow}</p>
					<h3 class="font-serif text-3xl mb-3 group-hover:text-accent transition-colors">{e.title}</h3>
					<p class="text-muted leading-relaxed mb-4">{e.description}</p>
					<span class="inline-block text-sm link-underline">자세히 보기 →</span>
				</a>
			))}
		</div>
	</section>

	<CTASection 
		title="어떤 행사를 준비 중이신가요?"
		description="단체 / 기관 예약은 미리 협의하실수록 더 풍성한 진행이 가능합니다."
		buttonLabel="문의하기"
		phone="041-546-1080"
	/>
</BaseLayout>