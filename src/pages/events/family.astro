---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import SmartImage from '../../components/SmartImage.astro';

const events = [
	{
		title: '돌잔치',
		eyebrow: 'DOLJANCHI',
		description: '아이의 첫 생일을 가족과 함께. 1층 전용 홀에서 진행되는 프리미엄 패키지.',
		href: '/events/doljanchi',
		image: '/images/events/doljanchi-cover.jpg',
	},
	{
		title: '칠·팔순',
		eyebrow: 'HWANGAB',
		description: '평생을 가족을 위해 살아오신 어르신을 위한 따뜻한 가족 행사.',
		href: '/events/hwangab',
		image: '/images/events/hwangab-cover.jpg',
	},
];
---

<BaseLayout title="가족 행사 · THE OLD MILL" description="돌잔치와 칠·팔순, 가족이 모이는 특별한 날">
	<PageHero
		eyebrow="FAMILY EVENTS"
		title="가족이 모이는<br/>특별한 날"
		subtitle="아이의 첫 생일부터 어르신의 큰 잔치까지. 가족의 의미 있는 순간을 함께 만들어드립니다."
	/>

	<section class="max-w-5xl mx-auto px-6 pb-24 reveal">
		<div class="grid md:grid-cols-2 gap-6 md:gap-8 reveal-stagger">
			{events.map(e => (
				<a href={e.href} class="group card-hover block">
					<div class="mb-5">
						<SmartImage 
							src={e.image}
							alt={e.title}
							aspectRatio="4/5"
							rounded="xl"
							label={e.title}
							hover
						/>
					</div>
					<p class="text-eyebrow mb-2 text-xs">{e.eyebrow}</p>
					<h3 class="font-serif text-3xl mb-3 group-hover:text-accent transition-colors">{e.title}</h3>
					<p class="text-muted leading-relaxed mb-4">{e.description}</p>
					<span class="inline-block text-sm link-underline">자세히 보기 →</span>
				</a>
			))}
		</div>
	</section>

	<CTASection 
		title="어떤 행사를 준비 중이신가요?"
		description="가족 행사는 미리 준비할수록 더 의미있는 시간이 됩니다."
		buttonLabel="문의하기"
		phone="041-546-1080"
	/>
</BaseLayout>