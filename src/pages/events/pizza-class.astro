---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';

const targets = [
	'어린이 생일파티',
	'유치원 / 어린이집 체험학습',
	'가족 단위 주말 체험',
	'단체 모임 (10명 이상)',
];
---

<BaseLayout title="피자체험 · THE OLD MILL" description="아이들이 직접 만드는 화덕 피자 체험">
	<PageHero
		eyebrow="PIZZA CLASS"
		title="아이들이 직접 만드는<br/>화덕 피자"
		subtitle="반죽부터 토핑까지 아이가 직접 만들고, 화덕에서 구워 먹는 특별한 경험."
	/>

	<Section eyebrow="FOR" title="이런 분들께 추천합니다">
		<ul class="space-y-4">
			{targets.map(t => (
				<li class="flex gap-4 items-start text-lg">
					<span class="text-accent text-2xl leading-none">·</span>
					<span>{t}</span>
				</li>
			))}
		</ul>
	</Section>

	<Section eyebrow="DETAILS" title="진행 시간 및 인원">
		<div class="grid md:grid-cols-2 gap-4">
			<div class="card-bordered p-6">
				<div class="text-sm text-muted mb-2">소요 시간</div>
				<div class="font-medium text-xl">약 60–90분</div>
			</div>
			<div class="card-bordered p-6">
				<div class="text-sm text-muted mb-2">권장 인원</div>
				<div class="font-medium text-xl">최소 ○명 — 최대 ○명</div>
			</div>
		</div>
		<p class="text-muted text-sm mt-6">※ 자세한 이용료와 인원은 문의 바랍니다.</p>
	</Section>

	<CTASection 
		title="피자체험 예약"
		description="단체 예약 시 메뉴와 진행 방식을 맞춤으로 안내드립니다."
		buttonLabel="예약 문의하기"
	/>
</BaseLayout>