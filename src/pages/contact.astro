---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="문의 · THE OLD MILL" description="올드밀 예약 및 문의">
	<PageHero
		eyebrow="CONTACT"
		title="문의 및 예약"
		subtitle="원하시는 날짜와 행사 종류를 알려주세요. 가능한 빨리 답변 드립니다."
	/>

	<section class="max-w-4xl mx-auto px-6 pb-20 grid md:grid-cols-2 gap-12">
		<!-- 연락처 정보 -->
		<div class="space-y-6">
			<div>
				<div class="text-sm text-muted mb-1">전화 (가장 빠른 답변)</div>
				<a href="tel:041-546-1080" class="font-serif text-3xl text-ink hover:text-accent transition-colors">
					041-546-1080
				</a>
			</div>
			<div>
				<div class="text-sm text-muted mb-1">운영 시간</div>
				<div class="text-lg">매일 11:00 - 21:30</div>
				<div class="text-muted text-sm mt-1">
					라스트오더 점심 15:00 / 저녁 20:30
				</div>
			</div>
			<div>
				<div class="text-sm text-muted mb-1">위치</div>
				<div class="text-lg">충남 아산시 (상세 주소)</div>
				<div class="text-muted text-sm mt-1">주차 가능</div>
			</div>
		</div>

		<!-- 문의 폼 (지금은 시각만, 백엔드 연결은 다음 단계) -->
		<form class="space-y-4">
			<div>
				<label class="block text-sm text-muted mb-2">이름</label>
				<input type="text" required class="w-full border border-border-warm rounded-lg px-4 py-3 bg-white focus:border-accent focus:outline-none" />
			</div>
			<div>
				<label class="block text-sm text-muted mb-2">연락처</label>
				<input type="tel" required class="w-full border border-border-warm rounded-lg px-4 py-3 bg-white focus:border-accent focus:outline-none" placeholder="010-0000-0000" />
			</div>
			<div>
				<label class="block text-sm text-muted mb-2">문의 유형</label>
				<select required class="w-full border border-border-warm rounded-lg px-4 py-3 bg-white focus:border-accent focus:outline-none">
					<option value="">선택해주세요</option>
					<option>돌잔치</option>
					<option>스몰웨딩</option>
					<option>피자체험</option>
					<option>일반 식사 예약</option>
					<option>기타</option>
				</select>
			</div>
			<div>
				<label class="block text-sm text-muted mb-2">희망 날짜 (선택)</label>
				<input type="date" class="w-full border border-border-warm rounded-lg px-4 py-3 bg-white focus:border-accent focus:outline-none" />
			</div>
			<div>
				<label class="block text-sm text-muted mb-2">내용</label>
				<textarea rows="4" class="w-full border border-border-warm rounded-lg px-4 py-3 bg-white focus:border-accent focus:outline-none" placeholder="예상 인원, 시간대 등을 알려주세요"></textarea>
			</div>
			<button type="submit" class="w-full bg-cta text-white py-3 rounded-lg hover:bg-accent transition-colors">
				문의 보내기
			</button>
			<p class="text-xs text-muted text-center">
				※ 폼 제출 기능은 추후 연결됩니다. 현재는 전화로 문의 부탁드립니다.
			</p>
		</form>
	</section>
</BaseLayout>